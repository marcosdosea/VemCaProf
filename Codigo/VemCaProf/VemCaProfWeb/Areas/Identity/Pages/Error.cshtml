@page
@model ErrorModel
@{
    ViewData["Title"] = "Erro";
}

<div class="text-center">
    <div class="identity-icon-danger"><i class="bi bi-exclamation-triangle"></i></div>
    <h1 class="identity-card-title mb-2">Ops! Algo deu errado.</h1>
    <p class="identity-text-muted">Ocorreu um erro ao processar sua solicitação.</p>

    @if (Model.ShowRequestId)
    {
        <p class="identity-text-muted small">
            <strong>ID da solicitação:</strong> <code class="text-danger">@Model.RequestId</code>
        </p>
    }

    <a asp-page="./Login" class="btn-identity mt-3">Ir para o login</a>
</div>
