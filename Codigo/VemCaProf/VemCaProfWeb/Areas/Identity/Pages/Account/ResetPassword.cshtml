@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Redefinir Senha";
}

<div class="text-center mb-4">
    <div class="identity-icon-info"><i class="bi bi-key"></i></div>
    <h1 class="identity-card-title">Redefinir senha</h1>
    <p class="identity-card-subtitle">Escolha uma nova senha para sua conta.</p>
</div>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
    <input asp-for="Input.Code" type="hidden" />

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.Email">E-mail</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="voce@exemplo.com" />
        </div>
        <span asp-validation-for="Input.Email" class="text-danger small"></span>
    </div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.Password">Nova senha</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Mínimo 6 caracteres" />
        </div>
        <span asp-validation-for="Input.Password" class="text-danger small"></span>
    </div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.ConfirmPassword">Confirmar senha</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Repita a senha" />
        </div>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn-identity">
        Redefinir senha <i class="bi bi-check-lg"></i>
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
