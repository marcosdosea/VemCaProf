@page
@model RegisterModel
@{
    ViewData["Title"] = Model.AlunoId.HasValue ? "Ativar Acesso" : "Criar Conta";
}

<div class="text-center mb-4">
    <h1 class="identity-card-title">@ViewData["Title"]</h1>
    <p class="identity-card-subtitle">Preencha os dados para criar sua conta no VemCáProf.</p>
</div>

<form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" asp-route-alunoId="@Model.AlunoId" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
    <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>

    @if (Model.AlunoId.HasValue)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-info-circle-fill"></i>
            <div>
                <strong>Criando acesso de Aluno</strong><br />
                O CPF foi preenchido automaticamente com os dados do perfil.
            </div>
        </div>
        <div class="identity-field">
            <div class="identity-field-label">
                <label asp-for="Input.Cpf">CPF do Aluno (Login)</label>
            </div>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person-vcard"></i></span>
                <input asp-for="Input.Cpf" class="form-control bg-light" readonly />
            </div>
            <span asp-validation-for="Input.Cpf" class="text-danger small"></span>
        </div>
    }
    else
    {
        <div class="identity-field">
            <div class="identity-field-label">
                <label asp-for="Input.TipoUsuario">Eu desejo me cadastrar como:</label>
            </div>
            <select asp-for="Input.TipoUsuario" class="form-control" aria-required="true">
                <option value="">-- Selecione seu Perfil --</option>
                <option value="Professor">Professor</option>
                <option value="Responsavel">Responsável</option>
            </select>
            <span asp-validation-for="Input.TipoUsuario" class="text-danger small"></span>
        </div>
        <div class="identity-field">
            <div class="identity-field-label">
                <label asp-for="Input.Cpf">CPF</label>
            </div>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person-vcard"></i></span>
                <input asp-for="Input.Cpf" class="form-control" placeholder="CPF (somente números)" />
            </div>
            <span asp-validation-for="Input.Cpf" class="text-danger small"></span>
        </div>
    }

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.Email">E-mail</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="voce@exemplo.com" />
        </div>
        <span asp-validation-for="Input.Email" class="text-danger small"></span>
    </div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.Password">Senha</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Mínimo 6 caracteres" />
        </div>
        <span asp-validation-for="Input.Password" class="text-danger small"></span>
    </div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.ConfirmPassword">Confirmar Senha</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Repita a senha" />
        </div>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn-identity mt-3">
        @(Model.AlunoId.HasValue ? "Ativar Acesso" : "Criar Conta") <i class="bi bi-check-lg"></i>
    </button>
</form>

<div class="text-center mt-4">
    <p class="identity-text-muted">
        Já tem uma conta?
        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="identity-link">Entrar</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
