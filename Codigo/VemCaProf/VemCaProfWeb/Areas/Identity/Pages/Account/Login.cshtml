@page
@model LoginModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="text-center mb-4">
    <h1 class="identity-card-title">Bem-vindo de volta</h1>
    <p class="identity-card-subtitle">Entre com sua conta para acessar o painel.</p>
</div>

<form id="account" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.Email">E-mail</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="voce@exemplo.com" />
        </div>
        <span asp-validation-for="Input.Email" class="text-danger small"></span>
    </div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.Password">Senha</label>
            <a asp-page="./ForgotPassword" class="identity-link small">Esqueci minha senha</a>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="••••••••" />
        </div>
        <span asp-validation-for="Input.Password" class="text-danger small"></span>
    </div>

    <div class="identity-check">
        <input asp-for="Input.RememberMe" />
        <label asp-for="Input.RememberMe">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
    </div>

    <button type="submit" class="btn-identity">
        Entrar <i class="bi bi-arrow-right"></i>
    </button>
</form>

@{
    if ((Model.ExternalLogins?.Count ?? 0) > 0)
    {
        <div class="position-relative my-4">
            <hr />
            <div class="position-absolute top-50 start-50 translate-middle px-3 bg-white text-muted small">ou</div>
        </div>
        <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="text-center">
            <p class="small text-muted mb-2">Entrar com</p>
            @foreach (var provider in Model.ExternalLogins!)
            {
                <button type="submit" class="btn btn-outline-secondary mx-1" name="provider" value="@provider.Name" title="Entrar usando sua conta @provider.DisplayName">
                    @provider.DisplayName
                </button>
            }
        </form>
    }
}

<div class="text-center mt-4">
    <p class="identity-text-muted">
        Novo por aqui?
        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="identity-link">Criar conta</a>
    </p>
    <p class="identity-text-muted mt-1">
        <a asp-page="./ResendEmailConfirmation" class="identity-link">Reenviar confirmação de e-mail</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
