@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "E-mail Enviado";
}

<div class="text-center">
    <div class="identity-icon-success"><i class="bi bi-check-lg"></i></div>
    <h1 class="identity-card-title mb-2">E-mail enviado!</h1>
    <p class="identity-text-muted">Verifique sua caixa de entrada e siga as instruções para redefinir sua senha.</p>
    <a asp-page="./Login" class="btn-identity mt-3">Voltar ao login</a>
</div>
