@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Reenviar Confirmação";
}

<div class="text-center mb-4">
    <div class="identity-icon-info"><i class="bi bi-envelope-exclamation"></i></div>
    <h1 class="identity-card-title">Reenviar confirmação</h1>
    <p class="identity-card-subtitle">Digite seu e-mail para receber novamente o link de confirmação.</p>
</div>

<form method="post">
    <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.Email">E-mail</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input asp-for="Input.Email" class="form-control" placeholder="voce@exemplo.com" />
        </div>
        <span asp-validation-for="Input.Email" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn-identity">
        Reenviar <i class="bi bi-send"></i>
    </button>
</form>

<div class="text-center mt-4">
    <p class="identity-text-muted">
        <a asp-page="./Login" class="identity-link">Voltar ao login</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
