@page
@model LockoutModel
@{
    ViewData["Title"] = "Conta Bloqueada";
}

<div class="text-center">
    <div class="identity-icon-danger"><i class="bi bi-shield-exclamation"></i></div>
    <h1 class="identity-card-title mb-2">Conta bloqueada</h1>
    <p class="identity-text-muted">Sua conta foi bloqueada por segurança. Tente novamente mais tarde.</p>
    <a asp-page="./Login" class="btn-identity mt-3">Voltar ao login</a>
</div>
