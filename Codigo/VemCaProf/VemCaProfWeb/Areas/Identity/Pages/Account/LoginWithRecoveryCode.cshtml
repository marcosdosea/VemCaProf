@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Código de Recuperação";
}

<div class="text-center mb-4">
    <div class="identity-icon-info"><i class="bi bi-key"></i></div>
    <h1 class="identity-card-title">Código de recuperação</h1>
    <p class="identity-card-subtitle">Digite seu código de recuperação para acessar sua conta.</p>
</div>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.RecoveryCode">Código de recuperação</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-key"></i></span>
            <input asp-for="Input.RecoveryCode" class="form-control" autocomplete="off" placeholder="Digite seu código" />
        </div>
        <span asp-validation-for="Input.RecoveryCode" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn-identity">
        Entrar <i class="bi bi-arrow-right"></i>
    </button>
</form>

<div class="text-center mt-4">
    <p class="identity-text-muted">
        <a asp-page="./Login" class="identity-link">Voltar ao login</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
