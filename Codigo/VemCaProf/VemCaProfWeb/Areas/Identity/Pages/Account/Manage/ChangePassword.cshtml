@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Alterar Senha";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="identity-card-title mb-3">@ViewData["Title"]</div>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="change-password-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.OldPassword">Senha atual</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" placeholder="••••••••" />
        </div>
        <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
    </div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.NewPassword">Nova senha</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
            <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" placeholder="Mínimo 6 caracteres" />
        </div>
        <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
    </div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.ConfirmPassword">Confirmar nova senha</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Repita a senha" />
        </div>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn-identity">
        Alterar senha <i class="bi bi-check-lg"></i>
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
