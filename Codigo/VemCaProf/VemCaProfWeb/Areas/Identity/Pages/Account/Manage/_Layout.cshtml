@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<div class="text-center mb-4">
    <h1 class="identity-card-title">Minha Conta</h1>
    <p class="identity-card-subtitle">Gerencie suas configurações de conta.</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <partial name="_ManageNav" />
    </div>
    <div class="col-md-8">
        @if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrEmpty(statusMessage))
        {
            var statusClass = statusMessage.StartsWith("Error") ? "identity-alert-danger" : "identity-alert-success";
            <div class="identity-alert @statusClass">
                <i class="bi @(statusMessage.StartsWith("Error") ? "bi-exclamation-circle-fill" : "bi-check-circle-fill")"></i>
                <span>@statusMessage</span>
            </div>
        }
        @RenderBody()
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
