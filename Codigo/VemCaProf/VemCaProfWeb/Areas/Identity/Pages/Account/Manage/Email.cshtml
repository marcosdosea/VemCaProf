@page
@model EmailModel
@{
    ViewData["Title"] = "Gerenciar E-mail";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<div class="identity-card-title mb-3">@ViewData["Title"]</div>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="email-form" method="post">
    <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>

    @if (Model.IsEmailConfirmed)
    {
        <div class="identity-field">
            <div class="identity-field-label">
                <label asp-for="Email">E-mail atual</label>
            </div>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-envelope-check text-success"></i></span>
                <input asp-for="Email" class="form-control" disabled />
            </div>
        </div>
    }
    else
    {
        <div class="identity-field">
            <div class="identity-field-label">
                <label asp-for="Email">E-mail atual</label>
            </div>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                <input asp-for="Email" class="form-control" disabled />
            </div>
            <div class="mt-2">
                <button asp-page-handler="SendVerificationEmail" type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-send"></i> Reenviar verificação
                </button>
            </div>
        </div>
    }

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.NewEmail">Novo e-mail</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input asp-for="Input.NewEmail" class="form-control" autocomplete="email" placeholder="novo@exemplo.com" />
        </div>
        <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn-identity">
        Alterar e-mail <i class="bi bi-check-lg"></i>
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
