@page
@model LogoutModel
@{
    ViewData["Title"] = "Sair";
}

@if (User.Identity?.IsAuthenticated ?? false)
{
    <div class="text-center">
        <div class="identity-icon-info"><i class="bi bi-box-arrow-right"></i></div>
        <h1 class="identity-card-title mb-2">Deseja sair?</h1>
        <p class="identity-text-muted">Você está prestes a encerrar sua sessão.</p>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
            <button type="submit" class="btn-identity">
                Sim, sair <i class="bi bi-box-arrow-right"></i>
            </button>
        </form>
    </div>
}
else
{
    <div class="text-center">
        <div class="identity-icon-success"><i class="bi bi-check-lg"></i></div>
        <h1 class="identity-card-title mb-2">Sessão encerrada</h1>
        <p class="identity-text-muted">Você saiu do sistema com sucesso.</p>
        <a asp-page="./Login" class="btn-identity mt-3">Voltar ao login</a>
    </div>
}
