@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Senha Redefinida";
}

<div class="text-center">
    <div class="identity-icon-success"><i class="bi bi-check-lg"></i></div>
    <h1 class="identity-card-title mb-2">Senha redefinida!</h1>
    <p class="identity-text-muted">Sua senha foi alterada com sucesso.</p>
    <a asp-page="./Login" class="btn-identity mt-3">Ir para o login</a>
</div>
