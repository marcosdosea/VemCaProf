@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Vincular Conta";
}

<div class="text-center mb-4">
    <div class="identity-icon-info"><i class="bi bi-link-45deg"></i></div>
    <h1 class="identity-card-title">Vincular conta</h1>
    <p class="identity-card-subtitle">
        Você foi autenticado com <strong>@Model.ProviderDisplayName</strong>.
        Informe seu e-mail para finalizar o cadastro.
    </p>
</div>

<form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="identity-field">
        <div class="identity-field-label">
            <label asp-for="Input.Email">E-mail</label>
        </div>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="voce@exemplo.com" />
        </div>
        <span asp-validation-for="Input.Email" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn-identity">
        Vincular e entrar <i class="bi bi-arrow-right"></i>
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
