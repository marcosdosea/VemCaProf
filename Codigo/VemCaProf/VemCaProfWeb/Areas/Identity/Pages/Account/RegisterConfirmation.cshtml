@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Confirmação de Cadastro";
}

<div class="text-center">
    <div class="identity-icon-success"><i class="bi bi-check-lg"></i></div>
    <h1 class="identity-card-title mb-2">Cadastro realizado!</h1>

    @if (Model.DisplayConfirmAccountLink)
    {
        <p class="identity-text-muted">Clique no link abaixo para confirmar sua conta:</p>
        <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn-identity mt-3">
            Confirmar conta <i class="bi bi-check-lg"></i>
        </a>
    }
    else
    {
        <p class="identity-text-muted">Verifique seu e-mail para confirmar sua conta.</p>
        <a asp-page="./Login" class="btn-identity mt-3">Ir para o login</a>
    }
</div>
