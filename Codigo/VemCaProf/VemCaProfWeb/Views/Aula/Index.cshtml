@model IEnumerable<VemCaProfWeb.Models.AulaModel>
@using Core.Enums

@{
    ViewData["Title"] = "Aulas";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cidade.css" />
}

<h1>Aulas</h1>

<p>
    <a asp-action="Create">Nova aula</a>
</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.DataHorarioInicio)</th>
            <th>@Html.DisplayNameFor(model => model.DataHorarioFinal)</th>
            <th>@Html.DisplayNameFor(model => model.Descricao)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>@Html.DisplayNameFor(model => model.Valor)</th>
            <th>@Html.DisplayNameFor(model => model.DataHoraPagamento)</th>
            <th>@Html.DisplayNameFor(model => model.MetodoPagamento)</th>
            <th>@Html.DisplayNameFor(model => model.NomeDisciplina)</th>
            <th>@Html.DisplayNameFor(model => model.NomeResponsavel)</th>
            <th>@Html.DisplayNameFor(model => model.NomeAluno)</th>
            <th>@Html.DisplayNameFor(model => model.NomeProfessor)</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.DataHorarioInicio)</td>
                <td>@Html.DisplayFor(modelItem => item.DataHorarioFinal)</td>
                <td>@Html.DisplayFor(modelItem => item.Descricao)</td>

                <td>
                    @Html.DisplayFor(modelItem => item.Status)
                </td>

                <td>@Html.DisplayFor(modelItem => item.Valor)</td>
                <td>@Html.DisplayFor(modelItem => item.DataHoraPagamento)</td>
                <td>@Html.DisplayFor(modelItem => item.MetodoPagamento)</td>
                <td>@Html.DisplayFor(modelItem => item.NomeDisciplina)</td>
                <td>@Html.DisplayFor(modelItem => item.NomeResponsavel)</td>
                <td>@Html.DisplayFor(modelItem => item.NomeAluno)</td>
                <td>@Html.DisplayFor(modelItem => item.NomeProfessor)</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Detalhes</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Excluir</a>

                    @if (item.Status != StatusEnum.Realizada && item.Status != StatusEnum.Cancelada && item.Status != StatusEnum.Confirmada)
                    {
                        <span>|</span>
                        <a href="#" class="text-success" data-bs-toggle="modal" data-bs-target="#modalConfirmar-@item.Id">
                            Confirmar
                        </a>

                        <div class="modal fade" id="modalConfirmar-@item.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Confirmar Realização de Aula</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body text-start">
                                        <p>Deseja confirma a aula <strong>@item.Descricao</strong>?</p>
                                        <p class="small text-muted">Regra: A confirmação só pode ser feita até 2hrs antes do início da aula.</p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Voltar</button>

                                        <form asp-action="Confirmar" asp-route-id="@item.Id" method="post">
                                            <button type="submit" class="btn btn-success">Sim, Confirmar</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                    }
                    @if (item.Status != StatusEnum.Realizada && item.Status != StatusEnum.Cancelada)
                    {
                        <span>|</span>
                        <a href="#" class="text-danger" data-bs-toggle="modal" data-bs-target="#modalCancelar-@item.Id">
                            Cancelar
                        </a>

                        <div class="modal fade" id="modalCancelar-@item.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Confirmar Cancelamento</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p>Tem certeza que deseja cancelar a aula de <strong>@item.Descricao</strong>?</p>
                                        <p class="small text-danger">Regra: Não é permitido cancelar no dia do agendamento.</p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>

                                        <form asp-action="Cancelar" asp-route-id="@item.Id" method="post">
                                            <button type="submit" class="btn btn-danger">Sim, Cancelar</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
