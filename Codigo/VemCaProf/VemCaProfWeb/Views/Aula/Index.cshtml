@model IEnumerable<VemCaProfWeb.Models.AulaModel>
@using Core.Enums

@{
    ViewData["Title"] = "Aulas";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/datatables.net/dataTables.bootstrap5.min.css" />
}

<div class="page-hero page-hero-gradient">
    <div class="page-hero-content">
        <div class="page-hero-badge"><i class="bi bi-journal-text"></i> Agenda</div>
        <h1 class="page-hero-title">@ViewData["Title"]</h1>
        <p class="page-hero-subtitle">Gerencie as aulas agendadas no sistema</p>
    </div>
</div>

<div class="page-actions">
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nova aula</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
        <table id="tabelaAulas" class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.DataHorarioInicio)</th>
                    <th>@Html.DisplayNameFor(model => model.DataHorarioFinal)</th>
                    <th>@Html.DisplayNameFor(model => model.Descricao)</th>
                    <th>@Html.DisplayNameFor(model => model.Status)</th>
                    <th>@Html.DisplayNameFor(model => model.Valor)</th>
                    <th>@Html.DisplayNameFor(model => model.DataHoraPagamento)</th>
                    <th>@Html.DisplayNameFor(model => model.MetodoPagamento)</th>
                    <th>@Html.DisplayNameFor(model => model.NomeDisciplina)</th>
                    <th>@Html.DisplayNameFor(model => model.NomeResponsavel)</th>
                    <th>@Html.DisplayNameFor(model => model.NomeAluno)</th>
                    <th>@Html.DisplayNameFor(model => model.NomeProfessor)</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.DataHorarioInicio)</td>
                        <td>@Html.DisplayFor(modelItem => item.DataHorarioFinal)</td>
                        <td>@Html.DisplayFor(modelItem => item.Descricao)</td>

                        <td>
                            @switch (item.Status)
                            {
                                case StatusEnum.Agendada: <span class="badge-dot badge-dot-info">Agendada</span> break;
                                case StatusEnum.Realizada: <span class="badge-dot badge-dot-success">Realizada</span> break;
                                case StatusEnum.Paga: <span class="badge-dot badge-dot-success">Paga</span> break;
                                case StatusEnum.AguardandoPagamento: <span class="badge-dot badge-dot-warning">Pendente</span> break;
                                case StatusEnum.Cancelada: <span class="badge-dot badge-dot-danger">Cancelada</span> break;
                                case StatusEnum.Confirmada: <span class="badge-dot badge-dot-primary">Confirmada</span> break;
                                default: <span class="badge-dot badge-dot-secondary">@item.Status</span> break;
                            }
                        </td>

                        <td>@Html.DisplayFor(modelItem => item.Valor)</td>
                        <td>@Html.DisplayFor(modelItem => item.DataHoraPagamento)</td>
                        <td>@Html.DisplayFor(modelItem => item.MetodoPagamento)</td>
                        <td>@Html.DisplayFor(modelItem => item.NomeDisciplina)</td>
                        <td>@Html.DisplayFor(modelItem => item.NomeResponsavel)</td>
                        <td>@Html.DisplayFor(modelItem => item.NomeAluno)</td>
                        <td>@Html.DisplayFor(modelItem => item.NomeProfessor)</td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-icon" title="Editar"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-action-icon" title="Detalhes"><i class="bi bi-eye"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-icon btn-action-icon-danger" title="Excluir"><i class="bi bi-trash"></i></a>

                            @if (item.Status != StatusEnum.Realizada && item.Status != StatusEnum.Cancelada && item.Status != StatusEnum.Confirmada)
                            {
                                <a href="#" class="btn-action-icon btn-action-icon-success" data-bs-toggle="modal" data-bs-target="#modalConfirmar-@item.Id" title="Confirmar">
                                    <i class="bi bi-check-lg"></i>
                                </a>

                                <div class="modal fade" id="modalConfirmar-@item.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Confirmar Realização de Aula</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body text-start">
                                                <p>Deseja confirma a aula <strong>@item.Descricao</strong>?</p>
                                                <p class="small text-muted">Regra: A confirmação só pode ser feita até 2hrs antes do início da aula.</p>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Voltar</button>

                                                <form asp-action="Confirmar" asp-route-id="@item.Id" method="post">
                                                    <button type="submit" class="btn btn-success">Sim, Confirmar</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            }
                            @if (item.Status != StatusEnum.Realizada && item.Status != StatusEnum.Cancelada)
                            {
                                <a href="#" class="btn-action-icon btn-action-icon-danger" data-bs-toggle="modal" data-bs-target="#modalCancelar-@item.Id" title="Cancelar">
                                    <i class="bi bi-x-lg"></i>
                                </a>

                                <div class="modal fade" id="modalCancelar-@item.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Confirmar Cancelamento</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>Tem certeza que deseja cancelar a aula de <strong>@item.Descricao</strong>?</p>
                                                <p class="small text-danger">Regra: Não é permitido cancelar no dia do agendamento.</p>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>

                                                <form asp-action="Cancelar" asp-route-id="@item.Id" method="post">
                                                    <button type="submit" class="btn btn-danger">Sim, Cancelar</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/datatables.net/dataTables.min.js"></script>
    <script src="~/lib/datatables.net/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#tabelaAulas').DataTable({
                language: { url: "/lib/datatables.net/pt-BR.json" },
                pageLength: 10,
                lengthChange: false,
                ordering: true,
                info: true,
                order: [[0, 'desc']]
            });
        });
    </script>
}
