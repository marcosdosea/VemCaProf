@model VemCaProfWeb.Models.PenalidadeModel
@{
    ViewData["Title"] = "Excluir";
}

<div class="page-hero page-hero-gradient">
    <div class="page-hero-content">
        <div class="page-hero-badge"><i class="bi bi-shield-exclamation"></i> Disciplina</div>
        <h1 class="page-hero-title">@ViewData["Title"]</h1>
        <p class="page-hero-subtitle">Tem certeza que deseja excluir esta penalidade?</p>
    </div>
</div>

<div class="alert alert-danger d-flex align-items-center gap-2">
    <i class="bi bi-exclamation-triangle-fill"></i>
    <span>Esta ação não pode ser desfeita.</span>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <dl class="row dl-modern">
            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Id)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Id)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.DataHorarioInicio)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.DataHorarioInicio)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.DataHoraFim)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.DataHoraFim)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Tipo)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Tipo)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Descricao)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Descricao)</dd>

            <dt class="col-sm-2">Professor</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.NomeProfessor)</dd>

            <dt class="col-sm-2">Responsável</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.NomeResponsavel)</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Excluir</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Voltar</a>
            </div>
        </form>
    </div>
</div>
