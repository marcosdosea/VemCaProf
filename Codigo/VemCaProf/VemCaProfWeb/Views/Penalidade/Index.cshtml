@model IEnumerable<VemCaProfWeb.Models.PenalidadeModel>

@{
    ViewData["Title"] = "Penalidades";
}



<div class="page-hero page-hero-gradient">
    <div class="page-hero-content">
        <div class="page-hero-badge"><i class="bi bi-shield-exclamation"></i> Disciplina</div>
        <h1 class="page-hero-title">@ViewData["Title"]</h1>
        <p class="page-hero-subtitle">Histórico de penalidades aplicadas.</p>
    </div>
</div>

<div class="page-actions">
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nova Penalidade</a>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
        <table id="tabelaPenalidades" class="table admin-table mb-0"
               data-admin-table data-actions-column="6" data-order-column="0" data-order-direction="desc"
               data-search-placeholder="Buscar tipo, professor ou responsável..."
               data-empty-message="Nenhuma penalidade encontrada.">
            <thead>
                <tr>
                    <th>Início</th>
                    <th>Fim</th>
                    <th>Tipo</th>
                    <th>Descrição</th>
                    <th>Professor</th>
                    <th>Responsável</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.DataHorarioInicio)</td>
                        <td>@Html.DisplayFor(modelItem => item.DataHoraFim)</td>
                        <td>@Html.DisplayFor(modelItem => item.Tipo)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Descricao) && item.Descricao.Length > 50)
                            {
                                <span>@item.Descricao.Substring(0, 50)...</span>
                            }
                            else
                            {
                                @Html.DisplayFor(modelItem => item.Descricao)
                            }
                        </td>
                        <td>@item.NomeProfessor</td>
                        <td>@item.NomeResponsavel</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-icon" title="Editar"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-action-icon" title="Detalhes"><i class="bi bi-eye"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-icon btn-action-icon-danger" title="Excluir"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
</div>
