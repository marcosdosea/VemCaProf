@model VemCaProfWeb.Models.PenalidadeModel

@{
    ViewData["Title"] = "Editar";
}

<div class="page-hero page-hero-gradient">
    <div class="page-hero-content">
        <div class="page-hero-badge"><i class="bi bi-shield-exclamation"></i> Disciplina</div>
        <h1 class="page-hero-title">Editar Penalidade</h1>
        <p class="page-hero-subtitle">Altere os dados da penalidade: @Model.Tipo</p>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="DataHorarioInicio" class="form-label-modern"></label>
                <input asp-for="DataHorarioInicio" class="form-control" type="datetime-local"
                       value="@(Model.DataHorarioInicio == default(System.DateTime) ? string.Empty : Model.DataHorarioInicio.ToString("yyyy-MM-ddTHH:mm"))" />
                <span asp-validation-for="DataHorarioInicio" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DataHoraFim" class="form-label-modern"></label>
                <input asp-for="DataHoraFim" class="form-control" type="datetime-local"
                       value="@(Model.DataHoraFim.HasValue ? Model.DataHoraFim.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)" />
                <span asp-validation-for="DataHoraFim" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Tipo" class="form-label-modern"></label>
                <input asp-for="Tipo" class="form-control" />
                <span asp-validation-for="Tipo" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Descricao" class="form-label-modern"></label>
                <input asp-for="Descricao" class="form-control" />
                <span asp-validation-for="Descricao" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IdProfessor" class="form-label-modern"></label>
                <select asp-for="IdProfessor" asp-items="@ViewBag.Professores" class="form-select">
                    <option value="">Selecione um professor</option>
                </select>
                <span asp-validation-for="IdProfessor" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IdResponsavel" class="form-label-modern"></label>
                <select asp-for="IdResponsavel" asp-items="@ViewBag.Responsaveis" class="form-select">
                    <option value="">Selecione um responsável</option>
                </select>
                <span asp-validation-for="IdResponsavel" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning"><i class="bi bi-check-lg"></i> Salvar Alterações</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
