@model IEnumerable<VemCaProfWeb.Models.PessoaModel>

@{
    ViewData["Title"] = "Gestão de Usuários";
    string tipoAtual = ViewBag.TipoAtual as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/datatables.net/dataTables.bootstrap5.min.css" />
}

<div class="page-hero page-hero-gradient">
  <div class="page-hero-content">
    <div class="page-hero-badge"><i class="bi bi-people"></i> Usuários</div>
    <h1 class="page-hero-title">@ViewData["Title"]</h1>
    <p class="page-hero-subtitle">Cadastre e gerencie professores, alunos e responsáveis.</p>
  </div>
</div>

<div class="page-actions">
  <div>
    <div class="dropdown">
      <button class="btn btn-primary dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-plus-lg"></i> Novo Cadastro
      </button>
      <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
        <li><a class="dropdown-item" asp-action="Create" asp-route-tipo="P">Professor</a></li>
        <li><a class="dropdown-item" asp-action="Create" asp-route-tipo="A">Aluno</a></li>
        <li><a class="dropdown-item" asp-action="Create" asp-route-tipo="R">Responsável</a></li>
      </ul>
    </div>
  </div>
  <div>
    <div class="btn-group" role="group">
      <a asp-action="Index" asp-route-tipo="P" class="btn @(tipoAtual == "P" ? "btn-primary" : "btn-outline-primary")">Professores</a>
      <a asp-action="Index" asp-route-tipo="A" class="btn @(tipoAtual == "A" ? "btn-success" : "btn-outline-success")">Alunos</a>
      <a asp-action="Index" asp-route-tipo="R" class="btn @(tipoAtual == "R" ? "btn-warning" : "btn-outline-warning")">Responsáveis</a>
      <a asp-action="Index" class="btn btn-outline-secondary">Todos</a>
    </div>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-body p-0">
    <div class="table-responsive">
    <table id="tabelaPessoas" class="table admin-table mb-0">
      <thead>
        <tr>
          <th>Nome</th>
          <th>Tipo</th>
          <th>CPF</th>
          <th>Email</th>
          <th>Cidade/UF</th>
          <th class="text-end">Ações</th>
        </tr>
      </thead>
      <tbody>
        @if (!Model.Any())
        {
          <tr>
            <td colspan="6" class="text-center text-muted py-4">Nenhum registro encontrado.</td>
          </tr>
        }
        else
        {
          @foreach (var item in Model)
          {
            <tr>
              <td>@item.Nome @item.Sobrenome</td>
              <td>
                @if (item.TipoPessoa == "P") { <span class="badge-dot badge-dot-primary">Professor</span> }
                else if (item.TipoPessoa == "A") { <span class="badge-dot badge-dot-success">Aluno</span> }
                else if (item.TipoPessoa == "R") { <span class="badge-dot badge-dot-warning">Responsável</span> }
              </td>
              <td>@item.Cpf</td>
              <td>@item.Email</td>
              <td>
                @if (!string.IsNullOrEmpty(item.Cidade))
                {
                  <span>@item.Cidade / @item.Estado</span>
                }
                else
                {
                  <span class="text-muted">-</span>
                }
              </td>
              <td class="text-end">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-icon" title="Editar"><i class="bi bi-pencil"></i></a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn-action-icon" title="Detalhes"><i class="bi bi-eye"></i></a>
                @if (User.IsInRole("Admin"))
                {
                  <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-icon btn-action-icon-danger" title="Remover"><i class="bi bi-trash"></i></a>
                }
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
    </div>
  </div>
</div>

@section Scripts {
    <script src="~/lib/datatables.net/dataTables.min.js"></script>
    <script src="~/lib/datatables.net/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#tabelaPessoas').DataTable({
                language: { url: "/lib/datatables.net/pt-BR.json" },
                pageLength: 10,
                lengthChange: false,
                ordering: true,
                info: true,
                columnDefs: [
                    { orderable: false, targets: [5] }
                ]
            });
        });
    </script>
}