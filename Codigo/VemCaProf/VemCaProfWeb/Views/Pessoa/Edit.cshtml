@model VemCaProfWeb.Models.PessoaModel

@{
    ViewData["Title"] = "Editar Perfil";
}

<div class="page-hero page-hero-gradient">
  <div class="page-hero-content">
    <div class="page-hero-badge"><i class="bi bi-pencil-square"></i> Edição</div>
    <h1 class="page-hero-title">@ViewData["Title"]</h1>
    <p class="page-hero-subtitle">Altere as informações do cadastro.</p>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-body">
    <form asp-action="Edit" enctype="multipart/form-data">

      <div asp-validation-summary="ModelOnly" class="text-danger"></div>

      <input type="hidden" asp-for="Id" />
      <input type="hidden" asp-for="TipoPessoa" />

      <partial name="_DadosPessoais" model="Model" />

      @if (Model.TipoPessoa == "P")
      {
        <div class="mt-3">
          <partial name="_ProfessorCampos" model="Model" />
        </div>
      }
      else if (Model.TipoPessoa == "A")
      {
        <div class="mt-3">
          <partial name="_AlunoCampos" model="Model" />
        </div>
      }
      else if (Model.TipoPessoa == "R")
      {
        <div class="mt-3">
          <partial name="_ResponsavelCampos" model="Model" />
        </div>
      }

      <hr class="text-muted" />
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Salvar Alterações</button>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Voltar para Lista</a>
      </div>

    </form>
  </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
