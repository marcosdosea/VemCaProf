@model VemCaProfWeb.Models.PessoaModel

@{
    ViewData["Title"] = "Novo Cadastro";

    string tituloPerfil = Model.TipoPessoa == "P" ? "Professor" :
        (Model.TipoPessoa == "A" ? "Aluno" : "Responsável");
}

<div class="page-hero page-hero-gradient">
  <div class="page-hero-content">
    <div class="page-hero-badge"><i class="bi bi-person-plus"></i> Cadastro</div>
    <h1 class="page-hero-title">@ViewData["Title"]</h1>
    <p class="page-hero-subtitle">@tituloPerfil</p>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-body">
    <form asp-action="Create" enctype="multipart/form-data">

      <div asp-validation-summary="All" class="text-danger"></div>

      <div asp-validation-summary="ModelOnly" class="text-danger"></div>

      <input type="hidden" asp-for="TipoPessoa" />

      <partial name="_DadosPessoais" model="Model" />

      @if (Model.TipoPessoa == "P")
      {
        <div class="mt-3">
          <partial name="_ProfessorCampos" model="Model" />
        </div>
      }
      else if (Model.TipoPessoa == "A")
      {
        <div class="mt-3">
          <partial name="_AlunoCampos" model="Model" />
        </div>
      }
      else if (Model.TipoPessoa == "R")
      {
        <div class="mt-3">
          <partial name="_ResponsavelCampos" model="Model" />
        </div>
      }

      <hr class="text-muted" />
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Finalizar Cadastro</button>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Cancelar</a>
      </div>

    </form>
  </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
