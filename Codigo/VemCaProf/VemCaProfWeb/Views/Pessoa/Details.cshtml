@model VemCaProfWeb.Models.PessoaModel

@{
    ViewData["Title"] = "Detalhes";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string titulo = Model.TipoPessoa == "P" ? "Professor" : 
                   (Model.TipoPessoa == "A" ? "Aluno" : "Responsável");
}
@section Styles {
    <link rel="stylesheet" href="~/css/pessoa.css" asp-append-version="true" />
}

<h1>Detalhes</h1>

@if (Model.NomesDependentes != null && Model.NomesDependentes.Any())
{
    <p class="text-muted">
        <i class="fa fa-child"></i> Responsável por: <strong>@string.Join(", ", Model.NomesDependentes)</strong>
    </p>
}

<div>
    <h4>@titulo</h4>
    <hr />
    
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Nome Completo</dt>
                <dd class="col-sm-9">@Model.Nome @Model.Sobrenome</dd>

                <dt class="col-sm-3">CPF</dt>
                <dd class="col-sm-9">@Model.Cpf</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Telefone</dt>
                <dd class="col-sm-9">@Model.Telefone</dd>

                <dt class="col-sm-3">Endereço</dt>
                <dd class="col-sm-9">
                    @if(!string.IsNullOrEmpty(Model.Cidade))
                    {
                        <span>@Model.Rua, @Model.Numero - @Model.Bairro (@Model.Cidade/@Model.Estado)</span>
                    }
                    else
                    {
                        <span class="text-muted">Endereço não informado</span>
                    }
                </dd>

                @if (Model.TipoPessoa == "P")
                {
                    <dt class="col-sm-12 mt-3 mb-2 border-bottom">Informações Profissionais</dt>

                    <dt class="col-sm-3">Descrição</dt>
                    <dd class="col-sm-9">@Model.DescricaoProfessor</dd>

                    <dt class="col-sm-3">Atende LIBRAS?</dt>
                    <dd class="col-sm-9 fw-bold">@(Model.Libras ? "Sim" : "Não")</dd>
                    
                    @if(Model.NomesDisciplinas != null && Model.NomesDisciplinas.Any())
                    {
                        <dt class="col-sm-3">Disciplinas</dt>
                        <dd class="col-sm-9">@string.Join(", ", Model.NomesDisciplinas)</dd>
                    }
                }
                else if (Model.TipoPessoa == "A")
                {
                    <dt class="col-sm-12 mt-3 mb-2 border-bottom">Informações do Aluno</dt>

                    <dt class="col-sm-3">Menor de Idade?</dt>
                    <dd class="col-sm-9">@(Model.AlunoDeMenor ? "Sim" : "Não")</dd>
                    
                    <dt class="col-sm-3">Aluno Atípico/PcD?</dt>
                    <dd class="col-sm-9">@(Model.Atipico ? "Sim" : "Não")</dd>

                    <dt class="col-sm-3">Responsável</dt>
                    <dd class="col-sm-9">
                        @if (Model.ResponsavelId != null)
                        {
                            <a asp-action="Details" asp-route-id="@Model.ResponsavelId">
                                @(Model.NomeResponsavel ?? "Ver Responsável")</a>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </dd>
                }
                else if (Model.TipoPessoa == "R")
                {
                    <dt class="col-sm-12 mt-3 mb-2 border-bottom">Informações do Responsável</dt>
                    <dt class="col-sm-3">Dependentes Cadastrados</dt>
                    <dd class="col-sm-9">
                        @Model.QuantidadeDeDependentes
                        @if (Model.NomesDependentes != null && Model.NomesDependentes.Any())
                        {
                            <div class="mt-2">
                                @foreach (var nome in Model.NomesDependentes)
                                {
                                    <span class="badge rounded-pill bg-info text-dark me-1">@nome</span>
                                }
                            </div>
                        }
                    </dd>
                    @* Alerta para cadastrar dependentes, se necessário *@
                    @if (Model.QuantidadeDeDependentes > 0)
                    {
                        int dependentesCadastrados = Model.Dependentes?.Count ?? 0;
                        if (dependentesCadastrados < Model.QuantidadeDeDependentes)
                        {
                            <div class="alert alert-info mt-3">
                                <i class="fa fa-info-circle"></i>
                                Você tem <strong>@dependentesCadastrados</strong> de <strong>@Model.QuantidadeDeDependentes</strong> dependentes cadastrados.
                                <a asp-action="Create" asp-route-tipo="A" class="alert-link">Cadastrar novo aluno</a>
                            </div>
                        }
                    }

                    @if (Model.Dependentes != null && Model.Dependentes.Any())
                    {
                        <dt class="col-sm-12 mt-4 mb-2"><i class="fa fa-users"></i> Gerenciar Acessos dos Dependentes</dt>
                        <dd class="col-sm-12">
                            <div class="table-responsive">
                                <table class="table table-bordered align-middle">
                                    <thead class="table-light">
                                    <tr>
                                        <th>Nome do Aluno</th>
                                        <th>CPF</th>
                                        <th class="text-center">Ação</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var dep in Model.Dependentes)
                                    {
                                        <tr>
                                            <td>@dep.Nome @dep.Sobrenome</td>
                                            <td class="text-muted">@dep.Cpf</td>
                                            <td class="text-center">
                                                <a asp-area="Identity" 
                                                   asp-page="/Account/Register" 
                                                   asp-route-alunoId="@dep.Id" 
                                                   class="btn btn-primary btn-sm">
                                                    <i class="fa fa-key"></i> Ativar Acesso
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        </dd>
                    }
                }
            </dl>
        </div>
    </div>
</div>

@* Bloco para ativar acesso de aluno *@
@if (Model.TipoPessoa == "A" && (User.IsInRole("Responsavel") || User.IsInRole("Admin")))
{
    <div class="card mt-4 border-primary shadow-sm">
        <div class="card-body d-flex align-items-center justify-content-between">
            <div>
                <h5 class="card-title text-primary mb-1">
                    <i class="fa fa-unlock-alt"></i> Acesso do Aluno
                </h5>
                <p class="card-text text-muted mb-0">
                    Este aluno ainda não possui login. Deseja liberar o acesso dele ao portal?
                </p>
            </div>
            <a asp-area="Identity" asp-page="/Account/Register" asp-route-alunoId="@Model.Id" 
               class="btn btn-primary btn-lg">
                <i class="fa fa-user-plus"></i> Ativar Acesso
            </a>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary btn-lg">Pagina Principal</a> |
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg">Editar</a> |
    <button type="button" class="btn btn-danger btn-lg" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal" data-id="@Model.Id">
        Excluir
    </button>
</div>

<!-- Modal de confirmação de exclusão (copiado da view Delete) -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmDeleteModalLabel">Confirmar exclusão</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Tem certeza que deseja excluir este item? Esta ação não pode ser desfeita.
            </div>
            <div class="modal-footer">
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Confirmar exclusão</button>
                </form>
            </div>
        </div>
    </div>
</div>