@model VemCaProfWeb.Models.PessoaModel

@{
    ViewData["Title"] = "Excluir Conta";
}

<div class="page-hero page-hero-gradient">
  <div class="page-hero-content">
    <div class="page-hero-badge"><i class="bi bi-person-x"></i> Exclusão</div>
    <h1 class="page-hero-title">@ViewData["Title"]</h1>
    <p class="page-hero-subtitle">Confirme a exclusão do usuário.</p>
  </div>
</div>

<div class="alert alert-danger d-flex align-items-center gap-2">
  <i class="bi bi-exclamation-triangle-fill"></i>
  <span><strong>Atenção:</strong> Esta ação não pode ser desfeita.</span>
</div>

<div class="admin-card">
  <div class="admin-card-body">
    <h4 class="mb-3">Dados do Usuário</h4>

    <dl class="row dl-modern">
      <dt class="col-sm-2">Nome</dt>
      <dd class="col-sm-10">@Model.Nome @Model.Sobrenome</dd>
      <dt class="col-sm-2">CPF</dt>
      <dd class="col-sm-10">@Model.Cpf</dd>
      <dt class="col-sm-2">Email</dt>
      <dd class="col-sm-10">@Model.Email</dd>
      <dt class="col-sm-2">Tipo</dt>
      <dd class="col-sm-10">
        @(Model.TipoPessoa == "P" ? "Professor" : (Model.TipoPessoa == "A" ? "Aluno" : "Responsável"))
      </dd>
    </dl>

    <hr class="text-muted" />
    <div class="d-flex gap-2">
      <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal" data-id="@Model.Id">
        <i class="bi bi-trash"></i> Excluir
      </button>
      <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Cancelar</a>
    </div>
  </div>
</div>

<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="confirmDeleteModalLabel">Confirmar exclusão</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Tem certeza que deseja excluir este item? Esta ação não pode ser desfeita.
      </div>
      <div class="modal-footer">
        <form asp-action="Delete" method="post">
          <input type="hidden" name="id" id="deleteId" />
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-danger">Confirmar exclusão</button>
        </form>
      </div>
    </div>
  </div>
</div>
