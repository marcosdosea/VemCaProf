@model VemCaProfWeb.Models.CidadeModel

@{
    ViewData["Title"] = "Remover";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cidade.css" />
}

<div class="city-page">
    <div class="city-wrap">

        <a asp-action="Index" class="city-back">
            <i class="bi bi-arrow-left"></i>
            Voltar para Lista
        </a>

        <div class="city-form-card">
            <div class="city-form-title">Remover Cidade</div>

            <div class="alert alert-warning">
                Tem certeza que deseja remover esta cidade?
            </div>

            <div class="mb-3">
                <div class="text-muted small">@Html.DisplayNameFor(model => model.Nome)</div>
                <div class="fw-semibold">@Html.DisplayFor(model => model.Nome)</div>
            </div>

            <div class="mb-3">
                <div class="text-muted small">@Html.DisplayNameFor(model => model.Estado)</div>
                <div class="fw-semibold">@Html.DisplayFor(model => model.Estado)</div>
            </div>

            <form asp-action="Delete" class="city-form-actions">
                <input type="hidden" asp-for="Id" />

                <button type="submit" class="btn btn-danger btn-city-primary">
                    <i class="bi bi-x-lg"></i>
                    Remover
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary btn-city-outline">
                    Cancelar
                </a>
            </form>
        </div>

    </div>
</div>