@model IEnumerable<VemCaProfWeb.Models.CidadeModel>

@{
    ViewData["Title"] = "Cidades";
}



<div class="page-hero page-hero-gradient">
  <div class="page-hero-content">
    <div class="page-hero-badge"><i class="bi bi-geo-alt"></i> Localização</div>
    <h1 class="page-hero-title">@ViewData["Title"]</h1>
    <p class="page-hero-subtitle">Cadastre e gerencie as cidades de atuação.</p>
  </div>
</div>

<div class="page-actions">
  <div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nova Cidade</a>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-body p-0">
    <div class="table-responsive">
    <table id="tabelaCidades" class="table admin-table mb-0"
           data-admin-table data-actions-column="2" data-order-column="0"
           data-search-placeholder="Buscar cidade ou estado..."
           data-empty-message="Nenhuma cidade cadastrada.">
      <thead>
        <tr>
          <th>@Html.DisplayNameFor(model => model.Nome)</th>
          <th>@Html.DisplayNameFor(model => model.Estado)</th>
          <th class="text-end">Ações</th>
        </tr>
      </thead>
      <tbody>
        @if (Model != null && Model.Any())
        {
          foreach (var item in Model)
          {
            <tr>
              <td><span class="badge-dot badge-dot-secondary">@item.Nome</span></td>
              <td class="text-secondary">@item.Estado</td>
              <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn-action-icon" title="Detalhes"><i class="bi bi-eye"></i></a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-icon" title="Editar"><i class="bi bi-pencil"></i></a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-icon btn-action-icon-danger" title="Remover"><i class="bi bi-trash"></i></a>
              </td>
            </tr>
          }
        }
        else
        {
          <tr>
            <td colspan="3" class="text-center text-muted py-4">Nenhuma cidade cadastrada.</td>
          </tr>
        }
      </tbody>
    </table>
    </div>
  </div>
</div>
