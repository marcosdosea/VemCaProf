@model IEnumerable<Core.DTO.AulaDTO>
@using VemCaProfWeb.Helpers
@using Core.Enums

@{
    ViewData["Title"] = "Pagamentos";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cidade.css" />
    <link rel="stylesheet" href="~/css/pagamento.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}

<div class="city-page">
    <div class="city-wrap">

        <a asp-action="Index" class="city-back">
            <i class="bi bi-arrow-left"></i>
            Voltar
        </a>

        <div class="pay-header city-header">
            <h1>Pagamentos</h1>
            <p>Visualize pagamentos e realize pagamentos pendentes</p>
        </div>

        <div class="city-card">
            <table class="table table-city table-hover align-middle">
                <thead>
                    <tr>
                        <th style="width:10%;">@Html.DisplayNameFor(m => m.First().Id)</th>
                        <th style="width:30%;">@Html.DisplayNameFor(m => m.First().Descricao)</th>
                        <th style="width:20%;">Data/Hora Pagamento</th>
                        <th style="width:15%;">@Html.DisplayNameFor(m => m.First().Valor)</th>
                        <th style="width:15%;">@Html.DisplayNameFor(m => m.First().Status)</th>
                        <th style="width:10%;" class="text-end">Ações</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    <span class="city-badge">@item.Descricao</span>
                                </td>

                                <td>
                                    @if (item.Status == StatusEnum.Paga)
                                    {
                                        <span class="pay-badge pay-badge-success">
                                            <i class="bi bi-check-circle"></i>
                                            @item.DataHoraPagamento.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="pay-badge pay-badge-warning">
                                            <i class="bi bi-hourglass-split"></i>
                                            Pendente
                                        </span>
                                    }
                                </td>

                                <td>R$ @item.Valor</td>

                                <td>
                                    @PagamentoDisplayHelper.StatusLabel(item.Status)
                                </td>

                                <td class="text-end">
                                    <div class="pay-actions">
                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-secondary pay-btn"
                                           title="Detalhes">
                                            <i class="bi bi-eye"></i>
                                            <span class="d-none d-sm-inline">Detalhes</span>
                                        </a>

                                        @if (item.Status != StatusEnum.Paga)
                                        {
                                            <a asp-action="Create"
                                               asp-route-id="@item.Id"
                                               class="btn btn-success pay-btn"
                                               title="Pagar">
                                                <i class="bi bi-cash-coin"></i>
                                                <span class="d-none d-sm-inline">Pagar</span>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="city-empty">
                                Nenhum pagamento encontrado.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>
