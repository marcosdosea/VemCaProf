@model IEnumerable<Core.DTO.AulaDTO>
@using VemCaProfWeb.Helpers
@using Core.Enums

@{
    ViewData["Title"] = "Pagamentos";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pagamento.css" />
}

<div class="page-hero page-hero-gradient">
    <div class="page-hero-content">
        <div class="page-hero-badge"><i class="bi bi-currency-dollar"></i> Financeiro</div>
        <h1 class="page-hero-title">@ViewData["Title"]</h1>
        <p class="page-hero-subtitle">Visualize pagamentos e realize pagamentos pendentes.</p>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
        <table id="tabelaPagamentos" class="table admin-table mb-0"
               data-admin-table data-actions-column="5" data-order-column="0" data-order-direction="desc"
               data-search-placeholder="Buscar pagamento ou status..."
               data-empty-message="Nenhum pagamento encontrado.">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(m => m.First().Id)</th>
                    <th>@Html.DisplayNameFor(m => m.First().Descricao)</th>
                    <th>Data/Hora Pagamento</th>
                    <th>@Html.DisplayNameFor(m => m.First().Valor)</th>
                    <th>@Html.DisplayNameFor(m => m.First().Status)</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><span class="fw-medium">@item.Descricao</span></td>
                            <td>
                                @if (item.Status == StatusEnum.Paga)
                                {
                                    <span class="pay-badge pay-badge-success">
                                        <i class="bi bi-check-circle"></i> @(item.DataHoraPagamento?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                    </span>
                                }
                                else
                                {
                                    <span class="pay-badge pay-badge-warning">
                                        <i class="bi bi-hourglass-split"></i> Pendente
                                    </span>
                                }
                            </td>
                            <td>R$ @item.Valor</td>
                            <td>@PagamentoDisplayHelper.StatusLabel(item.Status)</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-action-icon" title="Detalhes"><i class="bi bi-eye"></i></a>
                                @if (item.Status != StatusEnum.Paga)
                                {
                                    <a asp-action="Create" asp-route-id="@item.Id" class="btn-action-icon btn-action-icon-success" title="Pagar"><i class="bi bi-cash-coin"></i></a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Nenhum pagamento encontrado.</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
</div>
