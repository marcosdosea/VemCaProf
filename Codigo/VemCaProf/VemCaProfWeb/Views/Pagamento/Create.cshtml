@model VemCaProfWeb.Models.PagamentoModel

@{
    ViewData["Title"] = "Realizar Pagamento";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cidade.css" />
    <link rel="stylesheet" href="~/css/pagamento.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}


<div class="city-page">
    <div class="city-wrap">

        <a asp-action="Index" class="city-back">
            <i class="bi bi-arrow-left"></i>
            Voltar para Pagamentos
        </a>

        <div class="city-form-card">
            <div class="city-form-title">Realizar Pagamento</div>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input type="hidden" asp-for="IdAula" />

                <div class="mb-3">
                    <label class="form-label text-muted small">Aula</label>
                    <input class="form-control" value="@Model.DescricaoAula" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small">Valor</label>
                    <input class="form-control" value="@Model.Valor" readonly />
                </div>

                <div class="mb-3">
                    <label asp-for="MetodoPagamento" class="form-label text-muted small"></label>
                    <select asp-for="MetodoPagamento"
                            class="form-select"
                            asp-items="ViewBag.Metodos">
                    </select>
                    <span asp-validation-for="MetodoPagamento" class="text-danger small"></span>
                </div>

                <div class="city-form-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-city-outline">
                        <i class="bi bi-arrow-left me-1"></i>
                        Voltar
                    </a>

                    <button type="submit" class="btn btn-success btn-city-primary">
                        <i class="bi bi-check-lg"></i>
                        Confirmar Pagamento
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>
