@model VemCaProfWeb.Models.PagamentoModel

@{
    ViewData["Title"] = "Realizar Pagamento";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pagamento.css" />
}

<div class="page-hero page-hero-gradient">
    <div class="page-hero-content">
        <div class="page-hero-badge"><i class="bi bi-currency-dollar"></i> Financeiro</div>
        <h1 class="page-hero-title">@ViewData["Title"]</h1>
        <p class="page-hero-subtitle">Confirme os dados e selecione o método de pagamento.</p>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <input type="hidden" asp-for="IdAula" />

            <div class="mb-3">
                <label class="form-label text-muted small">Aula</label>
                <input class="form-control" value="@Model.DescricaoAula" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label text-muted small">Valor</label>
                <input class="form-control" value="@Model.Valor" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="MetodoPagamento" class="form-label text-muted small"></label>
                <select asp-for="MetodoPagamento"
                        class="form-select"
                        asp-items="ViewBag.Metodos">
                </select>
                <span asp-validation-for="MetodoPagamento" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>
                    Voltar
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg"></i>
                    Confirmar Pagamento
                </button>
            </div>
        </form>
    </div>
</div>
