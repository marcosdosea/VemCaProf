@model VemCaProfWeb.Models.DisponibilidadeHorarioModel

@{
    ViewData["Title"] = "Editar";
}

<div class="page-hero page-hero-gradient">
    <div class="page-hero-content">
        <div class="page-hero-badge"><i class="bi bi-clock"></i> Horários</div>
        <h1 class="page-hero-title">Editar horário</h1>
        <p class="page-hero-subtitle">Altere os dados do horário</p>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group mb-3">
                <label asp-for="HorarioInicio" class="control-label form-label-modern"></label>
                <input asp-for="HorarioInicio" type="time" class="form-control" />
                <span asp-validation-for="HorarioInicio" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="HorarioFim" class="control-label form-label-modern"></label>
                <input asp-for="HorarioFim" type="time" class="form-control" value="@Model.HorarioFim.ToString(@"hh\:mm")" />
                <span asp-validation-for="HorarioFim" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="IdProfessor" class="control-label form-label-modern"></label>
                <select asp-for="IdProfessor" asp-items="ViewBag.Professores" class="form-select">
                    <option value="">Selecione um professor</option>
                </select>
                <span asp-validation-for="IdProfessor" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
