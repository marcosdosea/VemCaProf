@model IEnumerable<VemCaProfWeb.Models.DisponibilidadeHorarioModel>

@{
    ViewData["Title"] = "Horários";
}



<div class="page-hero page-hero-gradient">
    <div class="page-hero-content">
        <div class="page-hero-badge"><i class="bi bi-clock"></i> Horários</div>
        <h1 class="page-hero-title">@ViewData["Title"]</h1>
        <p class="page-hero-subtitle">Gerencie os horários dos professores</p>
    </div>
</div>

<div class="page-actions">
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Novo Horário</a>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
        <table id="tabelaHorarios" class="table admin-table mb-0"
               data-admin-table data-actions-column="3" data-order-column="0"
               data-search-placeholder="Buscar professor ou horário..."
               data-empty-message="Nenhum horário cadastrado.">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.HorarioInicio)</th>
                    <th>@Html.DisplayNameFor(model => model.HorarioFim)</th>
                    <th>@Html.DisplayNameFor(model => model.NomeProfessor)</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model) {
                <tr>
                     <td>@Html.DisplayFor(modelItem => item.HorarioInicio)</td>
                     <td>@Html.DisplayFor(modelItem => item.HorarioFim)</td>
                    <td>@Html.DisplayFor(modelItem => item.NomeProfessor)</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-icon" title="Editar"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-action-icon" title="Detalhes"><i class="bi bi-eye"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-icon btn-action-icon-danger" title="Excluir"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
        }
            </tbody>
        </table>
        </div>
    </div>
</div>
