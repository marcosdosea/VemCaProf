@model IEnumerable<VemCaProfWeb.Models.DisciplinaModel>

@{
    ViewData["Title"] = "Disciplinas";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-table-container">
    <table class="table table-borderless table-hover">
        <thead>
            <tr>
                <th>Disciplina</th>
                <th>Descrição</th>
                <th>Nível</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                string textoNivel = (item.Nivel ?? "") switch

                {
                    "F1" => "Fundamental Menor",
                    "F2" => "Fundamental Maior",
                    "M1" => "Ensino Médio",
                    _ => item.Nivel ?? "Não Definido"
                };
                <tr>
                    <td class="fw-bold">@Html.DisplayFor(modelItem => item.Nome)</td>
                    <td class="text-muted">@Html.DisplayFor(modelItem => item.Descricao)</td>
                    <td><small>@textoNivel</small></td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm text-muted">•••</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav class="mt-4">
    <ul class="pagination justify-content-center">
        <li class="page-item disabled"><a class="page-link border-0 bg-transparent text-muted" href="#">&lt; Anterior</a></li>
        <li class="page-item"><a class="page-link border-0 text-primary fw-bold" href="#">1</a></li>
        <li class="page-item"><a class="page-link border-0 text-primary" href="#">2</a></li>
        <li class="page-item"><a class="page-link border-0 text-primary" href="#">3</a></li>
        <li class="page-item active"><a class="page-link" href="#">4</a></li>
    </ul>
</nav>