@model IEnumerable<VemCaProfWeb.Models.DisciplinaModel>

@{
    ViewData["Title"] = "Disciplinas";
}



<div class="page-hero page-hero-gradient">
  <div class="page-hero-content">
    <div class="page-hero-badge"><i class="bi bi-book"></i> Geral</div>
    <h1 class="page-hero-title">@ViewData["Title"]</h1>
    <p class="page-hero-subtitle">Gerencie as disciplinas oferecidas na plataforma.</p>
  </div>
</div>

<div class="page-actions">
  <div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nova Disciplina</a>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-body p-0">
    <div class="table-responsive">
    <table id="tabelaDisciplinas" class="table admin-table mb-0"
           data-admin-table data-actions-column="3" data-order-column="0"
           data-search-placeholder="Buscar disciplina, descrição ou nível..."
           data-empty-message="Nenhuma disciplina cadastrada.">
      <thead>
        <tr>
          <th>Disciplina</th>
          <th>Descrição</th>
          <th>Nível</th>
          <th class="text-end">Ações</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var item in Model)
        {
          string textoNivel = item.Nivel switch
          {
            "F1" => "Fundamental Menor",
            "F2" => "Fundamental Maior",
            "M1" => "Ensino Médio",
            _ => "Não definido"
          };
          <tr>
            <td class="fw-bold">@item.Nome</td>
            <td class="text-muted">@item.Descricao</td>
            <td><span class="badge-dot badge-dot-secondary">@textoNivel</span></td>
            <td class="text-end">
              <a asp-action="Details" asp-route-id="@item.Id" class="btn-action-icon" title="Detalhes"><i class="bi bi-eye"></i></a>
              <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-icon" title="Editar"><i class="bi bi-pencil"></i></a>
              <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-icon btn-action-icon-danger" title="Excluir"><i class="bi bi-trash"></i></a>
            </td>
          </tr>
        }
      </tbody>
    </table>
    </div>
  </div>
</div>
