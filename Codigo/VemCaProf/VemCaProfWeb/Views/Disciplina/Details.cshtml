@model VemCaProfWeb.Models.DisciplinaModel

@{
    ViewData["Title"] = "Detalhes da Disciplina";

    string textoNivel = Model.Nivel switch
    {
        "F1" => "Ensino Fundamental Menor (1º ao 5º ano)",
        "F2" => "Ensino Fundamental Maior (6º ao 9º ano)",
        "M1" => "Ensino Médio",
        _ => "Não informado"
    };
}

<div class="page-hero page-hero-gradient">
  <div class="page-hero-content">
    <div class="page-hero-badge"><i class="bi bi-book"></i> Geral</div>
    <h1 class="page-hero-title">@ViewData["Title"]</h1>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-body">
    <dl class="row dl-modern">
      <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Id)</dt>
      <dd class="col-sm-9">#@Html.DisplayFor(model => model.Id)</dd>

      <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Nome)</dt>
      <dd class="col-sm-9 fw-bold fs-5">@Html.DisplayFor(model => model.Nome)</dd>

      <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Descricao)</dt>
      <dd class="col-sm-9 text-muted">@Html.DisplayFor(model => model.Descricao)</dd>

      <dt class="col-sm-3">Nível de Ensino</dt>
      <dd class="col-sm-9">
        <span class="badge bg-light text-dark border">@textoNivel</span>
      </dd>
    </dl>

    <hr class="text-muted my-4" />

    <div class="d-flex gap-2">
      <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Editar Disciplina</a>
      <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>
  </div>
</div>
